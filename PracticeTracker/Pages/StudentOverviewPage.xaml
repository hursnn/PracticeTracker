<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PracticeTracker.StudentOverviewPage"
             Title="Student Overview">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="14">

            <Label x:Name="StudentNameLabel"
                   Text="Student"
                   FontSize="28"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />

            <Label Text="Weekly practice progress"
                   FontSize="15"
                   TextColor="Gray"
                   HorizontalOptions="Center"
                   Margin="0,0,0,10" />

            <Frame>
                <VerticalStackLayout Spacing="10">

                    <Label Text="Practice Summary"
                           FontSize="20"
                           FontAttributes="Bold" />

                    <Label x:Name="TodayTotalLabel"
                           Text="Today's total repetitions: 0"
                           FontSize="16" />

                    <Label x:Name="WeeklyTotalLabel"
                           Text="This week's total repetitions: 0"
                           FontSize="16" />

                    <Label x:Name="PracticeDaysLabel"
                           Text="Practice days this week: 0/7"
                           FontSize="16" />

                    <Label x:Name="MostPracticedLabel"
                           Text="Most practiced task: None"
                           FontSize="16" />

                </VerticalStackLayout>
            </Frame>

            <Button Text="Run Practice"
                    Clicked="OnRunPracticeClicked" />

            <Label Text="Practice History"
                   FontSize="20"
                   FontAttributes="Bold"
                   Margin="0,10,0,0" />

            <CollectionView x:Name="TasksCollectionView">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame>
                            <VerticalStackLayout Spacing="5">

                                <Label Text="{Binding TaskName}"
                                       FontSize="17"
                                       FontAttributes="Bold" />

                                <Label Text="{Binding Repetitions, StringFormat='Repetitions: {0}'}"
                                       FontSize="15" />

                                <Label Text="{Binding Date, StringFormat='Date: {0:MMM dd, yyyy h:mm tt}'}"
                                       FontSize="13"
                                       TextColor="Gray" />

                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>